<TMU|<tuple|1.1.0|2026.2.5>>

<style|<tuple|tmdoc|old-spacing|old-dots|old-lengths|framed-session>>

<\body>
  <tmdoc-title|The <name|TikZ> plug-in>

  <section|Basic Usage （基础使用）>

  <\session|tikz|default>
    <\output>
      Liii STEM interface to TikZ
    </output>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\draw (0,0);
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|0.4pt|0.4pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\draw (0,0) -- (0,1);
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|0.4pt|28.8527pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\draw (0,0) -- (1,0); \\draw (1,0) -- (1,1); \\draw (1,1) -- (0,1);
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|28.8527pt|28.8527pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\draw (0,0) -- (2,0) -- (1,1.5) -- cycle;
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|57.3055pt|43.0791pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\draw (0,0) rectangle (3,2);

      \\draw (1,1) circle (0.5);
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|85.7582pt|57.3055pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\draw[-\<gtr\>] (-2,0) -- (2,0) node[right] {$x$};

      \\draw[-\<gtr\>] (0,-2) -- (0,2) node[above] {$y$};

      \\foreach \\x in {-2,-1,0,1,2}

      \ \ \\draw (\\x,0.1) -- (\\x,-0.1) node[below] {\\x};

      \\foreach \\y in {-2,-1,0,1,2}

      \ \ \\draw (0.1,\\y) -- (-0.1,\\y) node[left] {\\y};
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|133.892pt|133.482pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\draw[step=0.5, gray!30] (-2,-2) grid (2,2);

      \\draw[-\<gtr\>] (-2,0) -- (2,0);

      \\draw[-\<gtr\>] (0,-2) -- (0,2);
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|114.211pt|114.211pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\draw[-\<gtr\>] (-3,0) -- (3,0) node[right] {$x$};

      \\draw[-\<gtr\>] (0,-2) -- (0,4) node[above] {$y$};

      \\draw[blue, domain=-2:2, smooth, variable=\\x] plot ({\\x}, {\\x*\\x});

      \\node[blue] at (1.5,2.5) {$y=x^2$};
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|183.498pt|184.032pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\draw[-\<gtr\>] (-3.5,0) -- (3.5,0);

      \\draw[-\<gtr\>] (0,-2.5) -- (0,2.5);

      \\draw[red, domain=-pi:pi, smooth, samples=100, variable=\\x] plot ({\\x}, {sin(\\x r)});

      \\draw[blue, domain=-pi:pi, smooth, samples=100, variable=\\x] plot ({\\x}, {cos(\\x r)});

      \\node[red] at (2,0.5) {$\\sin x$};

      \\node[blue] at (-2,0.8) {$\\cos x$};
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|199.569pt|142.664pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\draw (0,0) circle (1);

      \\draw (0,0) circle (1.5);

      \\draw (0,0) circle (2);

      \\foreach \\angle in {0,30,...,330}

      \ \ \\draw (0,0) -- (\\angle:2);
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|114.211pt|114.211pt||>
    </unfolded-io>
  </session>

  <section|Tikz Library Import （Tikz库导入）>

  <\session|tikz|default>
    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\usetikzlibrary{shapes.geometric}

      \\node[draw, circle] at (0,0) {A};

      \\node[draw, rectangle] at (2,0) {B};

      \\node[draw, diamond] at (1,1.5) {C};

      \\draw[-\<gtr\>] (0,0) -- (2,0);

      \\draw[-\<gtr\>] (2,0) -- (1,1.5);
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|73.9287pt|66.4385pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\usetikzlibrary{shapes.geometric}

      \\node[draw, star] at (0,0) {Star};
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|50.8925pt|48.4209pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\usetikzlibrary{calc}

      \\usetikzlibrary{arrows.meta}

      \\draw[-{Stealth}] (0,0) -- (1,1);
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|28.8527pt|28.8527pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\usetikzlibrary{shapes.symbols}

      \\node[draw, cloud] at (0,0) {Cloud};
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|54.7228pt|55.4771pt||>
    </unfolded-io>

    <\input>
      tikz]\ 
    <|input>
      \;
    </input>
  </session>

  <\section|<strong|Commutative diagram> （交换图）>
    \;
  </section>

  <\session|tikz|default>
    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\usetikzlibrary{arrows}

      \\node (A) at (0,2) {$A$};

      \\node (B) at (2,2) {$B$};

      \\node (C) at (0,0) {$C$};

      \\node (D) at (2,0) {$D$};

      \\draw[-\<gtr\>] (A) -- node[above] {$f$} (B);

      \\draw[-\<gtr\>] (A) -- node[left] {$g$} (C);

      \\draw[-\<gtr\>] (B) -- node[right] {$h$} (D);

      \\draw[-\<gtr\>] (C) -- node[below] {$k$} (D);
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|81.5274pt|86.4707pt||>
    </unfolded-io>
  </session>

  <\section|<strong|Feynman diagram> （费曼图）>
    \;
  </section>

  <\session|tikz|default>
    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\usetikzlibrary{decorations.pathmorphing}

      \\draw[thick] (-2,1) -- (0,0) node[midway, above left] {$e^-$};

      \\draw[thick] (-2,-1) -- (0,0) node[midway, below left] {$e^+$};

      \\draw[thick, decorate, decoration=snake] (0,0) -- (2,0) node[midway, above] {$\\gamma$};

      \\draw[thick] (2,0) -- (4,1) node[midway, above right] {$\\mu^-$};

      \\draw[thick] (2,0) -- (4,-1) node[midway, below right] {$\\mu^+$};
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|171.516pt|62.398pt||>
    </unfolded-io>
  </session>

  <\section|<strong|Benzene structure> （苯环）>
    \;
  </section>

  <\session|tikz|default>
    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\draw (30:1) -- (90:1) -- (150:1) -- (210:1) -- (270:1) -- (330:1) -- cycle;

      \\draw (30:0.8) -- (90:0.8);

      \\draw (150:0.8) -- (210:0.8);

      \\draw (270:0.8) -- (330:0.8);

      \\draw (90:1) -- (90:1.5) node[above] {OH};
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|49.6817pt|85.0311pt||>
    </unfolded-io>
  </session>

  For professinal chemical drawing, use <verbatim|chemfig>.

  <\session|tikz|default>
    <\output>
      Liii STEM interface to TikZ
    </output>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\usepackage{chemfig}

      \\chemfig{*6(=-=-=-)}
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|52.3617pt|60.4001pt||>
    </unfolded-io>

    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\node (molecule) at (0,0) {\\chemfig{*3(--=--)}}; \ 

      \\draw[-\<gtr\>, red] (molecule) -- (2,1); \ \ \ \ \ \ \ \ \ \ \ \ 
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|73.6289pt|48.3807pt||>
    </unfolded-io>

    <\input>
      tikz]\ 
    <|input>
      \;
    </input>
  </session>

  <\section|计算机流程图>
    \;
  </section>

  <\session|tikz|default>
    <\unfolded-io>
      tikz]\ 
    <|unfolded-io>
      \\usetikzlibrary{shapes.geometric, shapes.misc}

      \\node[draw, rounded rectangle] (start) at (0,4) {Start};

      \\node[draw, rectangle] (proc) at (0,2.5) {Input $x$};

      \\node[draw, diamond, aspect=2] (dec) at (0,0.5) {$x \<gtr\> 0$?};

      \\node[draw, rectangle] (yes) at (4,0.5) {Print "Positive"};

      \\node[draw, rounded rectangle] (stop) at (0,-1.5) {Stop};

      \\draw[-\<gtr\>] (start) -- (proc);

      \\draw[-\<gtr\>] (proc) -- (dec);

      \\draw[-\<gtr\>] (dec) -- node[above] {Yes} (yes);

      \\draw[-\<gtr\>] (dec) -- node[left] {No} (stop);

      \\draw[-\<gtr\>] (yes) -- (stop);\ 
    <|unfolded-io>
      <image|<tuple|<#>|pdf>|184.361pt|171.362pt||>
    <|unfolded-io>
      <image|<tuple|<#>>>,oldString:
    </unfolded-io>

    <\input>
      tikz]\ 
    <|input>
      \;
    </input>
  </session>

