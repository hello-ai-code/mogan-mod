    model new

    \;

    fish define sum(n)

    \ \ \ \ local s = 0

    \ \ \ \ loop local i (1,n)

    \ \ \ \ \ \ \ \ s += i

    \ \ \ \ endloop

    \ \ \ \ global sum = s end

    \;

    [s = sum(10)]

    fish list [s] ; 55

    \;

    fish define sum_even(n)

    \ \ \ \ local s = 0

    \ \ \ \ loop local i (n,0,-2)

    \ \ \ \ \ \ \ \ s += i

    \ \ \ \ endloop

    \ \ \ \ global sum_even = s end

    \;

    [s2 = sum_even(10)] fish list [s2] ; 30

    \;

    program return
