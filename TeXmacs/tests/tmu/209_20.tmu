    model new

    \;

    fish define long_sum

    \ \ \ \ local a1=1,a2=2,a3=3,a4=4,a5=5,a6=6,a7=7,a8=8,a9=9,a10=10

    \;

    \ \ \ \ ;设置中间变量temp

    \ \ \ \ local temp = a1+a2+a3+a4+a5

    \ \ \ \ global long_sum = temp+a6+a7+a8+a9+a10

    \ \ \ \ \ \ \ \ ;利用续航符 “...”

    \ \ \ \ global long_sum = a1+a2+a3+a4+a5+...

    \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ a6+a7+a8+a9+a10

    end

    \;

    [long_sum]

    \;

    program return
