  <\fish-code>
    model new

    \;

    fish define derive(y_mod,p_ratio)

    \ \ \ \ global s_mod=y_mod/(2.0*(1.0+p_ratio))

    \ \ \ \ global b_mod=y_mod/(3.0*(1.0-2.0*p_ratio))

    end

    \;

    [derive(5e8,0.25)]

    \;

    zone create brick size (2,2,2)

    zone cmodel assign elastic

    zone property bulk [b_mod] shear [s_mod]

    \;

    program return
  </fish-code>

