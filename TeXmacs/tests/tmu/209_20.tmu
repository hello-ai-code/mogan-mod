    fish define control_aliases(flag)

    \ \ \ \ section

    \ \ \ \ \ \ \ \ if flag then

    \ \ \ \ \ \ \ \ \ \ \ \ loop while flag > 0

    \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ flag -= 1

    \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ if flag = 2 then

    \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ exit_loop

    \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ end_if

    \ \ \ \ \ \ \ \ \ \ \ \ end_loop

    \ \ \ \ \ \ \ \ else

    \ \ \ \ \ \ \ \ \ \ \ \ exit_section

    \ \ \ \ \ \ \ \ end_section

    end
  </fish-code>
