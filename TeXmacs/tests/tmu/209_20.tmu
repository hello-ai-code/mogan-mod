  Code 48

  <\fish-code>
    model new

    \;

    fish define inspect_runtime

    \ \ \ \ local cwd = system.directory.current

    \ \ \ \ local lower_files = file.all('*.fis')

    \ \ \ \ local upper_files = file.all("*.FIS")

    \ \ \ \ local major = version.fish.major

    \ \ \ \ local total = math.abs(-5) + list.sum(list.range(1,4))

    \ \ \ \ io.out(string.build('cwd=', cwd))

    \ \ \ \ io.out(string.build('fis=', list.size(lower_files)))

    \ \ \ \ io.out(string.build('FIS=', list.size(upper_files)))

    \ \ \ \ io.out(string.build('major=', major))

    \ \ \ \ io.out(string.build('total=', total))

    end

    \;

    [inspect_runtime]

    \;

    program return
  </fish-code>

  Code 49

  <\fish-code>
    fish define scan_points(points)

    \ \ \ \ local total = 0.0

    \ \ \ \ local weights = list

    \ \ \ \ loop foreach local pnt points

    \ \ \ \ \ \ \ \ total += pnt-\<gtr\>x + pnt-\<gtr\>y + pnt-\<gtr\>z

    \ \ \ \ endloop

    \ \ \ \ weights =:: list.range(1,10)

    \ \ \ \ weights +=:: list.sequence(11,12,13)

    \ \ \ \ return total

    end
  </fish-code>

