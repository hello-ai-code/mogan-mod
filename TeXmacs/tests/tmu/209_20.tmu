  <\fish-code>
    model new

    \;

    fish define test

    \ \ \ \ local a=list ;创建空列表

    \;

    \ \ \ \ ; 创建元素相同的列表

    \ \ \ \ local b=list.create(10);创建一个长度为10的列表，元素默认为0

    \ \ \ \ local c=list.create(10,1);创建一个长度为10的列表，元素都为1

    \ \ \ \ local d=list.create(10,'a');创建一个长度为10的列表，元素都为'a'

    \;

    \ \ \ \ local e=list.sequence(1,2,'a',(1,2),math.pi) ;按顺序创建列表，元素类型可以不同

    \;

    \ \ \ \ local f=list.range(1,10) ;按元素为等差数列创建列表，间隔为默认为1

    \ \ \ \ local g=list.range(1,10,2) ;按元素为等差数列创建列表，间隔为2

    \ \ \ \ local h=list.range(10,1,-1) ;按元素为等差数列创建列表，间隔可为负值，该例中为-1

    \;

    \ \ \ \ io.out(list.size(h)) ; 输出列表的大小，此处为10

    \;

    end

    \;

    [test]

    \;

    program return
  </fish-code>

