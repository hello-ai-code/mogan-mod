  <\algorithm>
    Algorithm with listing and control structures

    <\listing>
      <algo-require|<math|n\<geq\>0>>

      <algo-ensure|<math|y=x<rsup|n>>>
    <|listing>
      <algo-state|<math|y\<leftarrow\>1>>

      <algo-state|<math|X\<leftarrow\>x>>

      <algo-state|<math|N\<leftarrow\>n>>

      <\algo-while|<math|N\<neq\>0>>
        <\algo-if|<math|N> is even>
          <algo-state|<math|X\<leftarrow\>X\<times\>X>>

          <algo-state|<math|N\<leftarrow\><frac|N|2>> >

          <\algo-if|<math|N> is odd>
            <algo-state|<math|y\<leftarrow\>y\<times\>X>>

            <algo-state|<math|N\<leftarrow\>N-1>>
          </algo-if>
        </algo-if>

        <algo-return|<math|y>>
      </algo-while>
    </listing>

    \;
  </algorithm>

  <\algorithm>
    Algorithm with listing and if-else-if

    <\listing>
      <algo-state|<math|y\<leftarrow\>1>>

      <\algo-if-else-if|<math|N> is even>
        <algo-state|<math|X\<leftarrow\>X\<times\>X>>

        <algo-state|<math|N\<leftarrow\><frac|N|2>> <algo-comment|even case>>
      <|algo-if-else-if|<math|N> is odd>
        <algo-state|<math|y\<leftarrow\>y\<times\>X>>

        <algo-state|<math|N\<leftarrow\>N-1>> <algo-comment|odd case>
      </algo-if-else-if|>

      <algo-return|<math|y>>
    </listing>
  </algorithm>

  \;

