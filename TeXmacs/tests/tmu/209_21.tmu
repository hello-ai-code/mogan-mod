  <\specified-algorithm|Test specified-algorithm with listing>
    <\listing>
      <algo-require|<math|n\<geq\>0>>

      <algo-ensure|<math|y=x<rsup|n>>>
    <|listing>
      <algo-state|<math|y\<leftarrow\>1>>

      <\algo-while|<math|N\<neq\>0>>
        <\algo-if|<math|N> is even>
          <algo-state|<math|X\<leftarrow\>X\<times\>X>>

          <algo-state|<math|N\<leftarrow\><frac|N|2>>>
